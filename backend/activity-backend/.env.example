# Activity Backend Configuration

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (shared with auth backend)
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Server
FASTAPI_ENV=development
PORT=5100
HOST=127.0.0.1

# Redis Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_NAMESPACE=activity-backend
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_DEFAULT_LIMIT=240
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
# Optional JSON override for per-method/per-route policies
# RATE_LIMIT_POLICIES=[{"path_pattern":"/api/v1/activities","methods":["POST"],"limit":30,"window_seconds":60}]
