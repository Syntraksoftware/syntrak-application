# Canonical map DB for this repo: Supabase Postgres + PostGIS.
# Set SYNTRAK_DATABASE_URL (postgresql+psycopg://…) to Supabase; run `alembic upgrade head` from backend/.
# This file is only for the optional Docker PostGIS service (offline local dev). Copy to postgres.env (gitignored).
# If something else already uses host port 5432, set POSTGRES_PORT=5433 in the environment
# when running `docker compose --profile postgis up` (see docker-compose.yml).
# Local connection: psql postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:POSTGRES_PORT/POSTGRES_DB

POSTGRES_USER=syntrak
POSTGRES_PASSWORD=syntrak_local_dev
POSTGRES_DB=syntrak
