# Application
APP_NAME=Syntrak Auth API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8080

# JWT Settings (access tokens are signed with SECRET_KEY)
# community-backend and activity-backend JWT_SECRET must use this SAME value.
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8081

# Security
BCRYPT_ROUNDS=12

# Supabase
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
# IMPORTANT: Use SERVICE ROLE KEY (not anon key) for backend operations
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
