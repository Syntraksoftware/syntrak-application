SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

JWT_SECRET=your-jwt-secret-here
FASTAPI_ENV=development
HOST=0.0.0.0
PORT=5001

# Redis Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_NAMESPACE=community-backend
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_DEFAULT_LIMIT=240
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
# Optional JSON override for per-method/per-route policies
# RATE_LIMIT_POLICIES=[{"path_pattern":"/api/v1/posts","methods":["POST"],"limit":20,"window_seconds":60}]
