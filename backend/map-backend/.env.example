# Map Backend Environment Variables

# Storage Backend
# - supabase: default, current production mode
# - postgis: map-backend uses local PostGIS container
MAP_STORAGE_BACKEND=supabase

# Supabase Configuration
# Required when MAP_STORAGE_BACKEND=supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Direct Postgres URI for map_trail tables, Alembic, asyncpg pool, OpenSkiMap sync (same project as above).
# Dashboard → Settings → Database → URI. Use postgresql+psycopg:// and sslmode=require.
# SYNTRAK_DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require

# PostGIS Configuration (used when MAP_STORAGE_BACKEND=postgis)
# You can set POSTGIS_DSN directly instead of host/user/password fields.
# POSTGIS_DSN=postgresql://syntrak:syntrak_local_dev@postgis:5432/syntrak
POSTGIS_HOST=postgis
POSTGIS_PORT=5432
POSTGIS_DB=syntrak
POSTGIS_USER=syntrak
POSTGIS_PASSWORD=syntrak_local_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256

# FastAPI Server Configuration
FASTAPI_ENV=development
HOST=127.0.0.1
PORT=5200

# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_STATIC_API_URL=https://maps.googleapis.com/maps/api/staticmap
GOOGLE_MAPS_ELEVATION_API_URL=https://maps.googleapis.com/maps/api/elevation/json
GOOGLE_MAPS_JS_API_URL=https://maps.googleapis.com/maps/api/js
GOOGLE_MAPS_MAP_ID=1001

# Static Map Configuration
STATIC_MAP_WIDTH=600
STATIC_MAP_HEIGHT=400
STATIC_MAP_ZOOM=12

# OpenSkiMap GeoJSON sync → map_trail.ski_runs (needs SYNTRAK_DATABASE_URL or postgis pool + alembic 002).
# Both must be set to register the 03:00 UTC job; SYNC_ENABLED alone without URL fails config validation.
# OPENSKIMAP_RUNS_GEOJSON_URL=https://example.com/ski-runs.geojson
# OPENSKIMAP_SYNC_ENABLED=true
